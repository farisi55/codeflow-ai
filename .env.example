# App
NODE_ENV=development
APP_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codeflow_ai

# Redis
REDIS_URL=redis://localhost:6379

# AI Providers (all optional - used by the backend fallback chain)
OPENCODE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=
ZAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_DEFAULT_MODEL=openai/gpt-4.1-mini

# Web Browsing Providers (optional - Tavily falls back to Firecrawl)
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
WEB_SEARCH_TIMEOUT_MS=15000

# Security
JWT_SECRET=changeme
API_KEY_ENCRYPTION_SECRET=changeme32chars
