# App
NODE_ENV=development
APP_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codeflow_ai

# Redis
REDIS_URL=redis://localhost:6379

# AI Providers (all optional - used by fallback chain)
PUTER_API_KEY=
OPENCODE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
SAMBANOVA_API_KEY=
ZAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Web Browsing Providers (optional - Tavily falls back to Firecrawl)
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
WEB_SEARCH_TIMEOUT_MS=15000

# Security
JWT_SECRET=changeme
API_KEY_ENCRYPTION_SECRET=changeme32chars
