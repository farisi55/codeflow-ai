# ============================================================================
# CodeFlow AI - root environment file
# Used by docker-compose.yml / docker-compose.dev.yml.
# Copy to .env and fill in values before running `pnpm docker:up`.
# ============================================================================

# ---- Ports ----
WEB_PORT=3000
APP_PORT=4000

# ---- Public URLs ----
# Used by the browser and must be reachable from the user's machine.
NEXT_PUBLIC_API_URL=http://localhost:4000
# Used by the backend to build static preview URLs.
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# ---- Project Path (Docker deployments) ----
# Absolute path ON THE HOST to a folder containing projects that CodeFlow AI
# may edit. It is mounted read-write at /workspace/projects in the API
# container.
#
# Windows example: PROJECTS_DIR=D:\Projects
# Linux example:   PROJECTS_DIR=/srv/codeflow-projects
#
# In the UI, use /workspace/projects/<project-folder> as Project Path.
PROJECTS_DIR=./projects

# ---- HTTP/HTTPS Proxy (corporate networks) ----
# Leave blank when no proxy is required. These values are passed to Docker
# builds and to running containers.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,api,web

# ---- DNS Resolvers ----
# Override these when Docker cannot use the network/VPN DNS resolvers.
DOCKER_DNS_1=1.1.1.1
DOCKER_DNS_2=8.8.8.8

# ---- AI Providers (all optional - backend fallback chain) ----
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
MISTRAL_API_KEY=
MISTRAL_DEFAULT_MODEL=mistral-large-latest
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openrouter/free
SAMBANOVA_API_KEY=
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_DEFAULT_MODEL=Meta-Llama-3.3-70B-Instruct
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_DEFAULT_MODEL=glm-5.1
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4
CLOUDFLARE_DEFAULT_MODEL=@cf/meta/llama-3.1-8b-instruct
GITHUB_MODELS_API_KEY=
GITHUB_MODELS_BASE_URL=https://models.github.ai/inference
GITHUB_MODELS_DEFAULT_MODEL=openai/gpt-4.1-mini

# Ollama - no key required. To use Ollama installed on the host, set:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# To use the optional Compose service, keep http://ollama:11434 and start
# Compose with --profile ollama.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# ---- OpenCode Agent ----
OPENCODE_TIMEOUT_MS=120000

# ---- Web Browsing (optional, Tavily falls back to Firecrawl) ----
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
WEB_SEARCH_TIMEOUT_MS=15000

# ---- Integrated Terminal / Preview ----
TERMINAL_ENABLED=true
TERMINAL_ALLOW_REMOTE=
PREVIEW_ENABLED=true
PREVIEW_ALLOW_REMOTE=
PREVIEW_READY_TIMEOUT_MS=30000
