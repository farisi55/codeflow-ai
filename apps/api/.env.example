# Server
NODE_ENV=development
APP_PORT=4000
CORS_ORIGIN=http://localhost:3000

# Integrated terminal
# Required in production; development enables the terminal by default.
TERMINAL_ENABLED=
# Keep blank unless terminal access from another machine is intentional.
TERMINAL_ALLOW_REMOTE=
# Optional shell override, for example pwsh.exe or powershell.exe.
TERMINAL_SHELL=

# Website preview
# Required in production; development enables preview by default.
PREVIEW_ENABLED=
# Keep blank unless preview access from another machine is intentional.
PREVIEW_ALLOW_REMOTE=
PREVIEW_READY_TIMEOUT_MS=30000
# Optional public API origin used to build static preview URLs.
API_PUBLIC_URL=http://localhost:4000

# AI Providers - add at least one key to enable backend AI responses
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
MISTRAL_API_KEY=
MISTRAL_DEFAULT_MODEL=mistral-large-latest
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openrouter/free
SAMBANOVA_API_KEY=
SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SAMBANOVA_DEFAULT_MODEL=Meta-Llama-3.3-70B-Instruct
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4
ZAI_DEFAULT_MODEL=glm-5.1

# Ollama - no key required
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# OpenCode Agent (install binary: npm install -g opencode-ai)
OPENCODE_TIMEOUT_MS=120000

# Web Browsing Providers (optional - Tavily falls back to Firecrawl)
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
WEB_SEARCH_TIMEOUT_MS=15000
